---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'About', href: '/about/' },
];
---

<header>
  <nav>
    <div class="nav-inner">
      <a href="/" class="site-title">My Blog</a>
      <ul class="nav-links">
        {navItems.map(({ label, href }) => (
          <li>
            <a href={href} class:list={[{ active: Astro.url.pathname === href }]}>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  header {
    padding: 0 1rem;
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text);
  }
</style>
