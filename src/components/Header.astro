---
import Search from './Search.astro';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'About', href: '/about/' },
  { label: '友链', href: '/friends/' },
];
---

<header>
  <nav>
    <div class="nav-inner">
      <a href="/" class="site-title">Calfjing的小世界</a>
      <div class="nav-actions">
        <button id="search-btn" class="search-btn" aria-label="Open search">🔎</button>
        <ul class="nav-links">
          {navItems.map(({ label, href }) => (
            <li>
              <a href={href} class:list={[{ active: Astro.url.pathname === href }]}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </nav>
<Search />
</header>

<style>
  header {
    padding: 0 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-inner {
    max-width: 72rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--accent);
  }
  
  /* Search button styling */
  .search-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--text);
    font-size: 1.1rem;
    cursor: pointer;
    margin-right: 0.25rem;
  }
  .search-btn:hover {
    color: var(--accent);
  }
</style>
