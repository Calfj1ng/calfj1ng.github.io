---
---

<audio id="bg-audio" src="/music/bg-music.mp4" loop preload="auto"></audio>
<button id="music-toggle" class="music-toggle" aria-label="播放音乐">🎵</button>

<style>
  .music-toggle {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 999;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(10, 18, 35, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--text);
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .music-toggle:hover {
    transform: scale(1.1);
    box-shadow: 0 4px 14px rgba(108, 180, 238, 0.3);
  }
  .music-toggle.playing {
    animation: glow 2s ease-in-out infinite;
  }
  @keyframes glow {
    0%, 100% { box-shadow: 0 2px 8px rgba(108, 180, 238, 0.15); }
    50% { box-shadow: 0 2px 16px rgba(108, 180, 238, 0.45); }
  }
</style>

<script>
  function setup() {
    const btn = document.getElementById('music-toggle');
    const audio = document.getElementById('bg-audio') as HTMLAudioElement | null;
    if (!btn || !audio) return;

    // Restore state from session (survives page navigation)
    const wasPlaying = sessionStorage.getItem('music-playing') === 'true';
    if (wasPlaying) {
      audio.play().catch(() => {});
      btn.textContent = '🔊';
      btn.classList.add('playing');
    }

    // Remove old listener before adding new one (View Transitions)
    const newBtn = btn.cloneNode(true) as HTMLElement;
    btn.parentNode?.replaceChild(newBtn, btn);

    newBtn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play().then(() => {
          newBtn.textContent = '🔊';
          newBtn.classList.add('playing');
          sessionStorage.setItem('music-playing', 'true');
        }).catch((e) => {
          console.warn('播放失败:', e.message);
        });
      } else {
        audio.pause();
        newBtn.textContent = '🎵';
        newBtn.classList.remove('playing');
        sessionStorage.setItem('music-playing', 'false');
      }
    });
  }

  setup();
  document.addEventListener('astro:page-load', setup);
</script>
