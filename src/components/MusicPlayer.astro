---
import { playlist } from '../data/playlist';
---

{playlist.length > 0 && (
  <button id="music-toggle" class="music-toggle" aria-label="播放音乐">🎵</button>
)}

<style>
  .music-toggle {
    position: fixed;
    top: 1rem;
    left: 1rem;
    z-index: 999;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: rgba(10, 18, 35, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: var(--text);
    font-size: 1.1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .music-toggle:hover {
    transform: scale(1.1);
    box-shadow: 0 4px 14px rgba(108, 180, 238, 0.3);
  }
  .music-toggle.playing {
    animation: glow 2s ease-in-out infinite;
  }
  @keyframes glow {
    0%, 100% { box-shadow: 0 2px 8px rgba(108, 180, 238, 0.15); }
    50% { box-shadow: 0 2px 16px rgba(108, 180, 238, 0.45); }
  }
</style>

<script>
  const SRC = '/music/bg-music.mp4';
  let audio: HTMLAudioElement | null = null;

  function getAudio(): HTMLAudioElement {
    if (!audio) {
      audio = new Audio(SRC);
      audio.loop = true;
      audio.volume = 0.4;
    }
    return audio;
  }

  function toggle() {
    const a = getAudio();
    const btn = document.getElementById('music-toggle');
    if (!btn) return;

    if (a.paused) {
      a.play().then(() => {
        btn.textContent = '🔊';
        btn.classList.add('playing');
      }).catch(() => {});
    } else {
      a.pause();
      btn.textContent = '🎵';
      btn.classList.remove('playing');
    }
  }

  // Bind button on every page load (View Transitions safe)
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('music-toggle');
    if (btn) {
      btn.removeEventListener('click', toggle);
      btn.addEventListener('click', toggle);
      // Restore visual state if audio exists and is playing
      if (audio && !audio.paused) {
        btn.textContent = '🔊';
        btn.classList.add('playing');
      }
    }
  });
</script>
