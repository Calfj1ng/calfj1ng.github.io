<div class="aurora-bg">
  <div class="aurora aurora-1"></div>
  <div class="aurora aurora-2"></div>
  <div class="aurora aurora-3"></div>
  <div class="aurora aurora-4"></div>
</div>

<style>
  .aurora-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    overflow: hidden;
    background: #0b0b1a;
  }

  .aurora {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    border-radius: 40%;
    filter: blur(80px);
    opacity: 0.5;
    mix-blend-mode: screen;
  }

  .aurora-1 {
    background: linear-gradient(
      135deg,
      rgba(0, 210, 180, 0.4) 0%,
      rgba(0, 150, 200, 0.2) 40%,
      transparent 70%
    );
    animation: drift1 18s ease-in-out infinite;
  }

  .aurora-2 {
    background: linear-gradient(
      225deg,
      rgba(120, 80, 255, 0.35) 0%,
      rgba(60, 40, 180, 0.15) 50%,
      transparent 80%
    );
    animation: drift2 22s ease-in-out infinite;
  }

  .aurora-3 {
    background: linear-gradient(
      315deg,
      rgba(0, 200, 255, 0.3) 0%,
      rgba(100, 50, 200, 0.15) 45%,
      transparent 75%
    );
    animation: drift3 25s ease-in-out infinite;
  }

  .aurora-4 {
    background: linear-gradient(
      45deg,
      rgba(50, 220, 130, 0.25) 0%,
      rgba(0, 180, 200, 0.1) 50%,
      transparent 70%
    );
    animation: drift4 20s ease-in-out infinite;
  }

  @keyframes drift1 {
    0%, 100% { transform: translate(10%, 10%) rotate(0deg) scale(1); }
    25% { transform: translate(20%, 5%) rotate(5deg) scale(1.05); }
    50% { transform: translate(15%, 15%) rotate(-3deg) scale(0.98); }
    75% { transform: translate(5%, 20%) rotate(8deg) scale(1.03); }
  }

  @keyframes drift2 {
    0%, 100% { transform: translate(15%, 5%) rotate(0deg) scale(1.02); }
    25% { transform: translate(5%, 15%) rotate(-6deg) scale(0.97); }
    50% { transform: translate(20%, 10%) rotate(4deg) scale(1.05); }
    75% { transform: translate(10%, 20%) rotate(-2deg) scale(1); }
  }

  @keyframes drift3 {
    0%, 100% { transform: translate(5%, 20%) rotate(2deg) scale(0.98); }
    33% { transform: translate(18%, 8%) rotate(-5deg) scale(1.06); }
    66% { transform: translate(8%, 15%) rotate(7deg) scale(0.95); }
  }

  @keyframes drift4 {
    0%, 100% { transform: translate(20%, 15%) rotate(-3deg) scale(1.01); }
    50% { transform: translate(8%, 5%) rotate(6deg) scale(0.96); }
  }

  /* 星星点缀层 */
  .aurora-bg::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 25% 55%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1.5px 1.5px at 40% 15%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 55% 75%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 70% 35%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1.5px 1.5px at 85% 60%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 15% 85%, rgba(255,255,255,0.25), transparent),
      radial-gradient(1px 1px at 50% 45%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1.5px 1.5px at 90% 10%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1px 1px at 35% 90%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 65% 5%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1px 1px at 5% 50%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1.5px 1.5px at 78% 82%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 45% 30%, rgba(255,255,255,0.28), transparent),
      radial-gradient(1px 1px at 92% 45%, rgba(255,255,255,0.32), transparent),
      radial-gradient(1px 1px at 20% 10%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1.5px 1.5px at 60% 92%, rgba(255,255,255,0.38), transparent),
      radial-gradient(1px 1px at 30% 65%, rgba(255,255,255,0.26), transparent),
      radial-gradient(1px 1px at 80% 25%, rgba(255,255,255,0.34), transparent),
      radial-gradient(1px 1px at 8% 72%, rgba(255,255,255,0.3), transparent);
    animation: twinkle 8s ease-in-out infinite alternate;
    z-index: 1;
    pointer-events: none;
  }

  @keyframes twinkle {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }
</style>

<script>
  // 无需 JS — 纯 CSS 动画，零性能开销
</script>
