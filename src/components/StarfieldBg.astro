---
---

<canvas id="sunset-bg"></canvas>

<style>
  #sunset-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
  html {
    background: #1a0a2e;
  }
  body {
    background: transparent !important;
  }
</style>

<script>
  function initSunsetBubbles() {
    if (window.__sunsetInit) return;
    window.__sunsetInit = true;

    const canvas = document.getElementById('sunset-bg') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d')!;
    let w = 0, h = 0;
    let animId = 0;

    interface Bubble {
      x: number;
      y: number;
      r: number;
      speed: number;
      wobbleAmp: number;
      wobbleSpeed: number;
      wobbleOffset: number;
      hue: number;
      saturation: number;
      lightness: number;
      alpha: number;
      glow: number;
    }

    const bubbles: Bubble[] = [];
    const MAX_BUBBLES = 50;

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }

    function createBubble(): Bubble {
      // 夕阳色调：橙、粉、紫、金、珊瑚
      const palettes = [
        { hue: 15, saturation: 90, lightness: 60 },   // 橙色
        { hue: 340, saturation: 80, lightness: 65 },   // 粉红
        { hue: 270, saturation: 60, lightness: 55 },   // 紫色
        { hue: 40, saturation: 95, lightness: 65 },    // 金色
        { hue: 5, saturation: 85, lightness: 60 },     // 珊瑚
        { hue: 320, saturation: 70, lightness: 60 },   // 玫红
        { hue: 25, saturation: 100, lightness: 55 },   // 深橙
        { hue: 290, saturation: 50, lightness: 50 },   // 淡紫
      ];
      const pal = palettes[Math.floor(Math.random() * palettes.length)];

      return {
        x: Math.random() * w,
        y: h + Math.random() * 100,
        r: Math.random() * 30 + 8,
        speed: Math.random() * 0.8 + 0.3,
        wobbleAmp: Math.random() * 30 + 10,
        wobbleSpeed: Math.random() * 0.02 + 0.005,
        wobbleOffset: Math.random() * Math.PI * 2,
        hue: pal.hue + (Math.random() - 0.5) * 20,
        saturation: pal.saturation,
        lightness: pal.lightness,
        alpha: Math.random() * 0.3 + 0.15,
        glow: Math.random() * 20 + 10,
      };
    }

    function init() {
      resize();
      bubbles.length = 0;
      for (let i = 0; i < MAX_BUBBLES; i++) {
        const b = createBubble();
        b.y = Math.random() * h; // 初始分散
        bubbles.push(b);
      }
    }

    function drawBackground() {
      // 夕阳渐变：底部深紫 → 中间橙红 → 顶部深蓝
      const grad = ctx.createLinearGradient(0, 0, 0, h);
      grad.addColorStop(0, '#0a0520');
      grad.addColorStop(0.25, '#1a0a3e');
      grad.addColorStop(0.45, '#4a1040');
      grad.addColorStop(0.6, '#8b1a3a');
      grad.addColorStop(0.75, '#c44a20');
      grad.addColorStop(0.88, '#e8781a');
      grad.addColorStop(0.95, '#f4a030');
      grad.addColorStop(1, '#f8c848');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, w, h);

      // 地平线发光
      const horizonY = h * 0.72;
      const glowGrad = ctx.createRadialGradient(w / 2, horizonY, 0, w / 2, horizonY, w * 0.6);
      glowGrad.addColorStop(0, 'rgba(255, 160, 50, 0.25)');
      glowGrad.addColorStop(0.5, 'rgba(255, 100, 50, 0.08)');
      glowGrad.addColorStop(1, 'transparent');
      ctx.fillStyle = glowGrad;
      ctx.fillRect(0, 0, w, h);
    }

    function drawBubbles(time: number) {
      for (const b of bubbles) {
        // 上浮
        b.y -= b.speed;

        // 左右摇摆
        const wobbleX = Math.sin(time * b.wobbleSpeed * 60 + b.wobbleOffset) * b.wobbleAmp;

        // 超出顶部则重置
        if (b.y < -b.r * 2) {
          b.y = h + b.r;
          b.x = Math.random() * w;
        }

        const drawX = b.x + wobbleX;

        // 越高越透明
        const heightFade = 1 - (1 - b.y / h) * 0.6;
        const a = b.alpha * Math.max(0, heightFade);

        // 发光效果
        const glowGrad = ctx.createRadialGradient(drawX, b.y, 0, drawX, b.y, b.r + b.glow);
        glowGrad.addColorStop(0, `hsla(${b.hue}, ${b.saturation}%, ${b.lightness}%, ${a})`);
        glowGrad.addColorStop(0.5, `hsla(${b.hue}, ${b.saturation}%, ${b.lightness}%, ${a * 0.4})`);
        glowGrad.addColorStop(1, `hsla(${b.hue}, ${b.saturation}%, ${b.lightness}%, 0)`);
        ctx.fillStyle = glowGrad;
        ctx.beginPath();
        ctx.arc(drawX, b.y, b.r + b.glow, 0, Math.PI * 2);
        ctx.fill();

        // 气泡主体（半透明圆）
        const bodyGrad = ctx.createRadialGradient(
          drawX - b.r * 0.3, b.y - b.r * 0.3, b.r * 0.1,
          drawX, b.y, b.r
        );
        bodyGrad.addColorStop(0, `hsla(${b.hue}, ${b.saturation}%, ${b.lightness + 20}%, ${a * 0.6})`);
        bodyGrad.addColorStop(0.7, `hsla(${b.hue}, ${b.saturation}%, ${b.lightness}%, ${a * 0.2})`);
        bodyGrad.addColorStop(1, `hsla(${b.hue}, ${b.saturation}%, ${b.lightness}%, ${a * 0.05})`);
        ctx.fillStyle = bodyGrad;
        ctx.beginPath();
        ctx.arc(drawX, b.y, b.r, 0, Math.PI * 2);
        ctx.fill();

        // 高光
        ctx.fillStyle = `rgba(255, 255, 255, ${a * 0.4})`;
        ctx.beginPath();
        ctx.arc(drawX - b.r * 0.25, b.y - b.r * 0.25, b.r * 0.15, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    // 小星星点缀在上方天空
    function drawStars() {
      const colors = ['rgba(255,200,150,0.4)', 'rgba(200,180,255,0.3)', 'rgba(255,255,200,0.35)'];
      for (let i = 0; i < 40; i++) {
        const sx = ((i * 137.508) % w);
        const sy = ((i * 97.3) % (h * 0.4));
        ctx.fillStyle = colors[i % 3];
        ctx.beginPath();
        ctx.arc(sx, sy, (i % 3 + 1) * 0.5, 0, Math.PI * 2);
        ctx.fill();
      }
    }

    let time = 0;
    function draw() {
      ctx.clearRect(0, 0, w, h);
      drawBackground();
      drawStars();
      drawBubbles(time);
      time += 0.016;
      animId = requestAnimationFrame(draw);
    }

    init();
    draw();

    window.addEventListener('resize', init);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) cancelAnimationFrame(animId);
      else draw();
    });
  }

  initSunsetBubbles();
</script>
