---

<div class="snowfall-container" id="snowfall-bg">
  <div class="night-sky"></div>
</div>

<style>
  .snowfall-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .night-sky {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      #0a0e1a 0%,
      #0f1b33 20%,
      #162040 40%,
      #1a2845 60%,
      #1e3050 80%,
      #243855 100%
    );
  }

  .snowflake {
    position: absolute;
    top: -20px;
    pointer-events: none;
    will-change: transform;
  }

  .snowflake-dot {
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255,255,255,0.95) 0%, rgba(200,215,240,0.6) 100%);
    box-shadow: 0 0 4px rgba(200, 220, 255, 0.3);
  }

  .snowflake-crystal {
    position: relative;
  }

  .snowflake-crystal::before {
    content: '❄';
    color: rgba(220, 235, 255, 0.7);
    text-shadow: 0 0 6px rgba(180, 210, 255, 0.4);
  }

  @keyframes snowfall {
    0% {
      transform: translateY(-20px) translateX(0) rotate(0deg);
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    90% {
      opacity: 0.8;
    }
    100% {
      transform: translateY(calc(100vh + 40px)) translateX(var(--drift)) rotate(var(--spin));
      opacity: 0;
    }
  }

  /* 小星星 */
  .star {
    position: absolute;
    border-radius: 50%;
    background: rgba(200, 220, 255, 0.5);
    animation: twinkle var(--twinkle-duration) ease-in-out infinite alternate;
  }

  @keyframes twinkle {
    0% { opacity: 0.2; transform: scale(0.8); }
    100% { opacity: 0.8; transform: scale(1.2); }
  }

  /* 底部积雪光晕 */
  .ground-glow {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 15%;
    background: linear-gradient(
      to top,
      rgba(180, 200, 230, 0.08) 0%,
      rgba(140, 170, 210, 0.03) 40%,
      transparent 100%
    );
    pointer-events: none;
  }
</style>

<script>
  function initSnowfall() {
    if ((window as any).__snowfallInit) return;
    (window as any).__snowfallInit = true;

    const container = document.getElementById('snowfall-bg');
    if (!container) return;

    // --- 星星 ---
    const starCount = 60;
    for (let i = 0; i < starCount; i++) {
      const star = document.createElement('div');
      star.className = 'star';
      const size = Math.random() * 2 + 0.5;
      star.style.cssText = `
        width: ${size}px;
        height: ${size}px;
        left: ${Math.random() * 100}%;
        top: ${Math.random() * 50}%;
        --twinkle-duration: ${Math.random() * 3 + 2}s;
        animation-delay: ${Math.random() * 5}s;
      `;
      container.appendChild(star);
    }

    // --- 底部光晕 ---
    const glow = document.createElement('div');
    glow.className = 'ground-glow';
    container.appendChild(glow);

    // --- 雪花 ---
    const snowflakeCount = 120;
    const DOT_RATIO = 0.8;

    for (let i = 0; i < snowflakeCount; i++) {
      const isDot = Math.random() < DOT_RATIO;
      const el = document.createElement('div');
      el.className = 'snowflake';

      if (isDot) {
        const size = Math.random() * 8 + 3;
        const inner = document.createElement('div');
        inner.className = 'snowflake-dot';
        inner.style.cssText = `width:${size}px;height:${size}px;`;
        el.appendChild(inner);
      } else {
        const size = Math.random() * 28 + 14;
        const inner = document.createElement('div');
        inner.className = 'snowflake-crystal';
        inner.style.cssText = `font-size:${size}px;`;
        el.appendChild(inner);
      }

      const left = Math.random() * 100;
      const duration = Math.random() * 25 + 15;
      const delay = Math.random() * 35;
      const drift = (Math.random() * 80 + 20) * (Math.random() < 0.5 ? 1 : -1);
      const spin = Math.random() * 720 - 360;

      el.style.cssText = `
        left: ${left}%;
        --drift: ${drift}px;
        --spin: ${spin}deg;
        animation: snowfall ${duration}s linear ${delay}s infinite;
      `;

      container.appendChild(el);
    }
  }

  initSnowfall();
</script>
