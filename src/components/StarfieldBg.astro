---
---

<canvas id="starfield-bg"></canvas>

<style>
  #starfield-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }
  /* 让内容浮在背景之上 */
  body {
    background: transparent !important;
  }
  html {
    background: #0f0f1a;
  }
</style>

<script>
  function initStarfield() {
    if (window.__starfieldInit) return;
    window.__starfieldInit = true;

    const canvas = document.getElementById('starfield-bg') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d')!;
    let w = 0, h = 0;
    let mouseX = -9999, mouseY = -9999;
    let animId = 0;

    interface Star {
      x: number;
      y: number;
      vx: number;
      vy: number;
      r: number;
      baseAlpha: number;
      alpha: number;
      pulse: number;
      pulseSpeed: number;
    }

    const STAR_COUNT = 180;
    const LINK_DIST = 120;
    const MOUSE_DIST = 160;
    const stars: Star[] = [];

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }

    function createStar(): Star {
      return {
        x: Math.random() * w,
        y: Math.random() * h,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        r: Math.random() * 1.8 + 0.5,
        baseAlpha: Math.random() * 0.5 + 0.3,
        alpha: 0,
        pulse: Math.random() * Math.PI * 2,
        pulseSpeed: Math.random() * 0.02 + 0.005,
      };
    }

    function init() {
      resize();
      stars.length = 0;
      for (let i = 0; i < STAR_COUNT; i++) {
        stars.push(createStar());
      }
    }

    function draw() {
      ctx.clearRect(0, 0, w, h);

      // 连线
      for (let i = 0; i < stars.length; i++) {
        for (let j = i + 1; j < stars.length; j++) {
          const dx = stars[i].x - stars[j].x;
          const dy = stars[i].y - stars[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < LINK_DIST) {
            const opacity = (1 - dist / LINK_DIST) * 0.15;
            ctx.beginPath();
            ctx.moveTo(stars[i].x, stars[i].y);
            ctx.lineTo(stars[j].x, stars[j].y);
            ctx.strokeStyle = `rgba(140, 120, 255, ${opacity})`;
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }

      // 鼠标连线
      for (const star of stars) {
        const dx = star.x - mouseX;
        const dy = star.y - mouseY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MOUSE_DIST) {
          const opacity = (1 - dist / MOUSE_DIST) * 0.25;
          ctx.beginPath();
          ctx.moveTo(star.x, star.y);
          ctx.lineTo(mouseX, mouseY);
          ctx.strokeStyle = `rgba(180, 140, 255, ${opacity})`;
          ctx.lineWidth = 0.6;
          ctx.stroke();
        }
      }

      // 绘制星星
      for (const star of stars) {
        star.pulse += star.pulseSpeed;
        star.alpha = star.baseAlpha + Math.sin(star.pulse) * 0.2;

        // 鼠标靠近时微微推开
        const dx = star.x - mouseX;
        const dy = star.y - mouseY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < MOUSE_DIST && dist > 0) {
          const force = (1 - dist / MOUSE_DIST) * 0.5;
          star.vx += (dx / dist) * force;
          star.vy += (dy / dist) * force;
        }

        // 移动
        star.x += star.vx;
        star.y += star.vy;

        // 速度衰减
        star.vx *= 0.99;
        star.vy *= 0.99;

        // 边界环绕
        if (star.x < -10) star.x = w + 10;
        if (star.x > w + 10) star.x = -10;
        if (star.y < -10) star.y = h + 10;
        if (star.y > h + 10) star.y = -10;

        // 绘制
        const glow = star.r * 3;
        const gradient = ctx.createRadialGradient(star.x, star.y, 0, star.x, star.y, glow);
        gradient.addColorStop(0, `rgba(200, 180, 255, ${star.alpha})`);
        gradient.addColorStop(0.4, `rgba(140, 120, 255, ${star.alpha * 0.4})`);
        gradient.addColorStop(1, `rgba(140, 120, 255, 0)`);

        ctx.beginPath();
        ctx.arc(star.x, star.y, glow, 0, Math.PI * 2);
        ctx.fillStyle = gradient;
        ctx.fill();

        // 实心核心
        ctx.beginPath();
        ctx.arc(star.x, star.y, star.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(220, 210, 255, ${star.alpha + 0.2})`;
        ctx.fill();
      }

      animId = requestAnimationFrame(draw);
    }

    init();

    window.addEventListener('resize', init);
    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });
    document.addEventListener('mouseleave', () => {
      mouseX = -9999;
      mouseY = -9999;
    });

    // 页面不可见时暂停动画，节省资源
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cancelAnimationFrame(animId);
      } else {
        draw();
      }
    });

    draw();
  }

  initStarfield();
</script>
