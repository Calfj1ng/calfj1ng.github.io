---
// ============================================
//  🎨 在这里切换背景！把数字改成 1~5 即可
// ============================================
const BG_STYLE = 1;

// 1 = 🔥 赛博朋克霓虹网格 (当前)
// 2 = 🌊 动态渐变流光
// 3 = 🎆 流星夜空
// 4 = ✨ 粒子网格 (鼠标交互)
// 5 = 🔮 毛玻璃浮动球

const styleClass = `bg-style-${BG_STYLE}`;
---

<div class:list={['animated-bg', styleClass]}>
  {BG_STYLE === 4 && <canvas id="particle-grid-bg"></canvas>}
</div>

<style>
  .animated-bg {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
  }
  canvas {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  /* ========== 1. 赛博朋克霓虹网格 ========== */
  .bg-style-1 { background: #0a0014; }

  /* ========== 2. 动态渐变流光 ========== */
  .bg-style-2 {
    background: linear-gradient(-45deg, #0f0c29, #302b63, #24243e, #0f0c29);
    background-size: 400% 400%;
    animation: gradient-shift 15s ease infinite;
  }
  @keyframes gradient-shift {
    0%   { background-position: 0% 50%; }
    50%  { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .bg-style-2::before,
  .bg-style-2::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.4;
  }
  .bg-style-2::before {
    width: 60vw; height: 60vw;
    top: -20%; left: -10%;
    background: radial-gradient(circle, rgba(168,85,247,0.5), transparent 70%);
    animation: float-a 20s ease-in-out infinite;
  }
  .bg-style-2::after {
    width: 50vw; height: 50vw;
    bottom: -20%; right: -10%;
    background: radial-gradient(circle, rgba(0,240,255,0.4), transparent 70%);
    animation: float-b 18s ease-in-out infinite;
  }
  @keyframes float-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(10vw, 10vh) scale(1.1); }
  }
  @keyframes float-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-10vw, -8vh) scale(1.15); }
  }

  /* ========== 3. 流星夜空 ========== */
  .bg-style-3 {
    background: radial-gradient(ellipse at bottom, #1a1a3e 0%, #0a0a1a 100%);
  }
  .bg-style-3::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background-image:
      radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 25% 55%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1.5px 1.5px at 40% 15%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1px 1px at 55% 75%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 70% 35%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1.5px 1.5px at 85% 60%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 15% 85%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 50% 45%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1.5px 1.5px at 90% 10%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 35% 90%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 65% 5%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 5% 50%, rgba(255,255,255,0.4), transparent),
      radial-gradient(2px 2px at 48% 22%, rgba(255,255,255,0.8), transparent),
      radial-gradient(1px 1px at 78% 82%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1.5px 1.5px at 32% 68%, rgba(200,180,255,0.6), transparent),
      radial-gradient(1px 1px at 92% 45%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 8% 32%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1.5px 1.5px at 62% 92%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 22% 8%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 75% 50%, rgba(200,200,255,0.4), transparent);
    animation: twinkle 6s ease-in-out infinite alternate;
  }
  @keyframes twinkle {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }
  /* 流星 */
  .bg-style-3::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 200%;
    background:
      linear-gradient(315deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.8) 50%, rgba(255,255,255,0) 100%) no-repeat,
      linear-gradient(315deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.6) 50%, rgba(255,255,255,0) 100%) no-repeat,
      linear-gradient(315deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.7) 50%, rgba(255,255,255,0) 100%) no-repeat,
      linear-gradient(315deg, rgba(255,255,255,0) 0%, rgba(255,255,255,0.5) 50%, rgba(255,255,255,0) 100%) no-repeat;
    background-size: 200px 2px, 150px 1.5px, 180px 2px, 120px 1px;
    background-position: 20% 15%, 60% 40%, 80% 10%, 40% 65%;
    animation: shoot 8s linear infinite;
  }
  @keyframes shoot {
    0%   { transform: translate(0, 0) rotate(-45deg); opacity: 0; }
    5%   { opacity: 1; }
    15%  { opacity: 0; }
    100% { transform: translate(-800px, 800px) rotate(-45deg); opacity: 0; }
  }

  /* ========== 4. 粒子网格 (鼠标交互) ========== */
  .bg-style-4 { background: #0a0a1a; }

  /* ========== 5. 毛玻璃浮动球 ========== */
  .bg-style-5 { background: #0f0f1a; }
</style>

{/* ---- 各背景专属 JS ---- */}
{BG_STYLE === 1 && (
  <script define:vars={{}}>
    // 赛博朋克网格
    const canvas = document.getElementById('cybergrid-bg') || document.querySelector('.bg-style-1')?.appendChild(Object.assign(document.createElement('canvas'), {id:'cybergrid-bg'}));
    if (canvas && !window.__cyberInit) {
      window.__cyberInit = true;
      const ctx = canvas.getContext('2d');
      let w, h, animId, time = 0;

      function resize() { w = canvas.width = window.innerWidth; h = canvas.height = window.innerHeight; }
      resize();

      function draw() {
        ctx.clearRect(0, 0, w, h);
        const horizon = h * 0.45;

        // 天空
        const sky = ctx.createLinearGradient(0, 0, 0, h * 0.5);
        sky.addColorStop(0, '#0a0014'); sky.addColorStop(1, '#120030');
        ctx.fillStyle = sky; ctx.fillRect(0, 0, w, h * 0.5);

        // 地面
        const gnd = ctx.createLinearGradient(0, horizon, 0, h);
        gnd.addColorStop(0, '#0a0014'); gnd.addColorStop(1, '#050008');
        ctx.fillStyle = gnd; ctx.fillRect(0, horizon, w, h);

        // 城市剪影
        ctx.fillStyle = '#0a0014';
        const bldgs = [[.05,.03,.06],[.09,.02,.1],[.12,.04,.04],[.18,.015,.14],[.21,.03,.07],[.26,.05,.03],[.33,.02,.12],[.36,.04,.05],[.42,.01,.18],[.44,.03,.08],[.49,.04,.06],[.55,.02,.15],[.58,.03,.04],[.63,.015,.1],[.67,.05,.03],[.74,.02,.13],[.78,.04,.05],[.84,.015,.09],[.88,.03,.07],[.93,.04,.04]];
        for (const [bx,bw,bh] of bldgs) {
          ctx.fillRect(bx*w, horizon-bh*h, bw*w, bh*h);
          if (Math.random()>.4) {
            ctx.fillStyle = Math.random()>.5?'rgba(0,240,255,0.25)':'rgba(255,0,255,0.15)';
            ctx.fillRect(bx*w+bw*w*.2, horizon-bh*h+bh*h*.3, bw*w*.25, bh*h*.12);
            ctx.fillStyle = '#0a0014';
          }
        }

        // 水平线
        for (let i=0;i<30;i++) {
          const t=i/30, pt=Math.pow(t,1.8);
          const y=horizon+(h-horizon)*pt+((time*40)%((h-horizon)/30))*pt;
          if (y<horizon||y>h) continue;
          ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(w,y);
          ctx.strokeStyle=`rgba(0,240,255,${.08+pt*.25})`; ctx.lineWidth=1; ctx.stroke();
        }

        // 竖线
        const vx=w/2;
        for (let i=-12;i<=12;i++) {
          const a=.15+(1-Math.abs(i)/12)*.2;
          ctx.beginPath(); ctx.moveTo(vx+i*3,horizon); ctx.lineTo(vx+i*(w/24)*1.2,h);
          ctx.strokeStyle=`rgba(168,85,247,${a})`; ctx.lineWidth=1; ctx.stroke();
        }

        // 地平线发光
        ctx.beginPath(); ctx.moveTo(0,horizon); ctx.lineTo(w,horizon);
        ctx.strokeStyle='rgba(0,240,255,0.4)'; ctx.lineWidth=1.5; ctx.stroke();

        // 扫描线
        ctx.fillStyle='rgba(0,0,0,0.03)';
        for (let y=0;y<h;y+=3) ctx.fillRect(0,y,w,1);

        // 星星
        const colors=['#00f0ff','#ff00ff','#a855f7','#fff'];
        for (let i=0;i<60;i++) {
          const sx=((i*137.5)%w), sy=((i*97.3)%(h*.45));
          const fl=Math.sin(time*2*Math.PI*((i*.01)+.003)*60+sx)*.3;
          ctx.globalAlpha=Math.max(0,Math.min(1,.3+fl));
          ctx.fillStyle=colors[i%4];
          ctx.beginPath(); ctx.arc(sx,sy,((i%3)+.3)*.6,0,Math.PI*2); ctx.fill();
        }
        ctx.globalAlpha=1;

        time+=.016;
        animId=requestAnimationFrame(draw);
      }

      draw();
      window.addEventListener('resize', resize);
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) cancelAnimationFrame(animId); else draw();
      });
    }
  </script>
)}

{BG_STYLE === 4 && (
  <script define:vars={{}}>
    // 粒子网格 (鼠标交互)
    const cvs = document.getElementById('particle-grid-bg');
    if (cvs && !window.__particleGridInit) {
      window.__particleGridInit = true;
      const ctx = cvs.getContext('2d');
      let w, h, mouseX = -9999, mouseY = -9999, animId;

      const SPACING = 40;
      const INFLUENCE = 150;
      let dots: {ox:number,oy:number,x:number,y:number}[] = [];

      function resize() {
        w = cvs.width = window.innerWidth;
        h = cvs.height = window.innerHeight;
        dots = [];
        for (let x = SPACING/2; x < w; x += SPACING)
          for (let y = SPACING/2; y < h; y += SPACING)
            dots.push({ox:x, oy:y, x, y});
      }
      resize();

      function draw() {
        ctx.clearRect(0, 0, w, h);
        for (const d of dots) {
          const dx = d.ox - mouseX, dy = d.oy - mouseY;
          const dist = Math.sqrt(dx*dx + dy*dy);
          if (dist < INFLUENCE && dist > 0) {
            const f = (1 - dist/INFLUENCE) * 20;
            d.x = d.ox + (dx/dist)*f;
            d.y = d.oy + (dy/dist)*f;
          } else {
            d.x += (d.ox - d.x) * 0.1;
            d.y += (d.oy - d.y) * 0.1;
          }

          const distMouse = Math.sqrt((d.x-mouseX)**2 + (d.y-mouseY)**2);
          const alpha = distMouse < INFLUENCE ? 0.15 + (1-distMouse/INFLUENCE)*0.5 : 0.12;

          ctx.beginPath();
          ctx.arc(d.x, d.y, 1.2, 0, Math.PI*2);
          ctx.fillStyle = `rgba(0, 240, 255, ${alpha})`;
          ctx.fill();
        }

        // 连线
        for (let i=0; i<dots.length; i++) {
          const a = dots[i];
          const distA = Math.sqrt((a.x-mouseX)**2+(a.y-mouseY)**2);
          if (distA > INFLUENCE) continue;
          for (let j=i+1; j<dots.length; j++) {
            const b = dots[j];
            const d = Math.sqrt((a.x-b.x)**2+(a.y-b.y)**2);
            if (d < SPACING*1.6) {
              ctx.beginPath(); ctx.moveTo(a.x,a.y); ctx.lineTo(b.x,b.y);
              ctx.strokeStyle=`rgba(168,85,247,${(1-d/(SPACING*1.6))*0.2})`;
              ctx.lineWidth=0.5; ctx.stroke();
            }
          }
        }

        animId = requestAnimationFrame(draw);
      }
      draw();

      window.addEventListener('resize', resize);
      document.addEventListener('mousemove', e => { mouseX=e.clientX; mouseY=e.clientY; });
      document.addEventListener('mouseleave', () => { mouseX=-9999; mouseY=-9999; });
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) cancelAnimationFrame(animId); else draw();
      });
    }
  </script>
)}

{/* 浮动球 HTML */}
{BG_STYLE === 5 && (
  <div class="orb-container" style="position:absolute;top:0;left:0;width:100%;height:100%;overflow:hidden;pointer-events:none;">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="orb orb-4"></div>
    <div class="orb orb-5"></div>
  </div>
)}

<style>
  /* 浮动球样式 */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.5;
  }
  .orb-1 { width:35vw;height:35vw;top:-10%;left:-5%;background:rgba(168,85,247,0.4);animation:orb1 20s ease-in-out infinite; }
  .orb-2 { width:30vw;height:30vw;top:60%;right:-8%;background:rgba(0,240,255,0.35);animation:orb2 18s ease-in-out infinite; }
  .orb-3 { width:25vw;height:25vw;top:30%;left:50%;background:rgba(255,0,255,0.3);animation:orb3 22s ease-in-out infinite; }
  .orb-4 { width:20vw;height:20vw;top:70%;left:20%;background:rgba(0,200,255,0.25);animation:orb4 16s ease-in-out infinite; }
  .orb-5 { width:28vw;height:28vw;top:5%;right:30%;background:rgba(168,85,247,0.3);animation:orb5 24s ease-in-out infinite; }

  @keyframes orb1 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(8vw,6vh) scale(1.1);} }
  @keyframes orb2 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(-6vw,-8vh) scale(1.15);} }
  @keyframes orb3 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(5vw,-5vh) scale(0.9);} }
  @keyframes orb4 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(-4vw,6vh) scale(1.1);} }
  @keyframes orb5 { 0%,100%{transform:translate(0,0) scale(1);} 50%{transform:translate(-7vw,4vh) scale(1.05);} }
</style>
