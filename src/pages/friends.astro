---
import BaseLayout from '../layouts/BaseLayout.astro';

type Friend = {
  name: string;
  description: string;
  href: string;
  color: string;
};

const friends: Friend[] = [];
---

<BaseLayout title="友链 | Calfjing的小世界" description="友情链接">
  <section class="friends-list">
    <h1>友链</h1>
    <p class="subtitle">以下是本站推荐的友情链接，点击访问</p>

    <div class="grid">
      {friends.length === 0 && (
        <p class="empty-hint">暂无友链，如需交换友链请联系 <a href="mailto:jing1173@outlook.com">jing1173@outlook.com</a></p>
      )}
      {friends.map((f) => (
        <a class="friend-card" href={f.href} target="_blank" rel="noopener">
          <div class="avatar" style={`background: ${f.color};`}>
            {f.name.charAt(0)}
          </div>
          <div class="info">
            <div class="name">{f.name}</div>
            <div class="description">{f.description}</div>
          </div>
          <span class="visit">Visit</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .friends-list h1 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .subtitle { color: var(--text-muted); margin-bottom: 1.5rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }
  .friend-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    background: var(--surface);
    color: var(--text);
  }
  .avatar {
    width: 40px; height: 40px; border-radius: 50%; display: grid; place-items: center; color: white; font-weight: 700;
  }
  .info { flex: 1; }
  .name { font-weight: 600; }
  .description { font-size: 0.9rem; color: var(--text-muted); }
  .visit { color: var(--text-muted); }
  .empty-hint { color: var(--text-muted); line-height: 1.8; }
  .empty-hint a { color: var(--accent); }
</style>
